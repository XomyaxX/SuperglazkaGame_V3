# === SERVER CONFIG ===
PORT=3000

# === SECURITY ===
# Generate strong random keys (use: openssl rand -hex 32)
JWT_SECRET=change-this-to-random-64-char-string
ADMIN_API_KEY=change-this-to-random-32-char-string

# === EMAIL (Resend) ===
# Get API key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@yourdomain.com

# === FRONTEND ===
# Must match your real domain (for CORS)
FRONTEND_URL=https://yourdomain.com
